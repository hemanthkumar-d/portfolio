{
  "name": "portfolio-root",
  "version": "1.0.0",
  "private": true,
  "description": "Root configuration and automation scripts for the MERN Stack Portfolio",
  "scripts": {
    "install:all": "npm install --prefix client && npm install --prefix server",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "seed": "npm run seed --prefix server",
    "test": "npm run test --prefix server",
    "build:client": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
